          <img
            src="https://res.cloudinary.com/dggitwduo/image/upload/v1775631839/SB_BARBER_LOGO_evz0fu.png"
            alt="Sizabantu Barbershop"
            className="h-10 md:h-12 object-contain"
            referrerPolicy="no-referrer"
          />
